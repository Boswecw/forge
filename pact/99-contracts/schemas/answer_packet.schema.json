{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bds.local/pact/v1/schemas/answer_packet.schema.json",
  "title": "PACT V1 Answer Packet",
  "allOf": [
    {
      "$ref": "./packet_base.schema.json"
    },
    {
      "type": "object",
      "required": [
        "task_goal",
        "instruction_block",
        "support_blocks",
        "grounding_refs",
        "answer_constraints"
      ],
      "properties": {
        "packet_class": {
          "const": "answer_packet"
        },
        "task_goal": {
          "type": "string"
        },
        "instruction_block": {
          "type": "string"
        },
        "support_blocks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "grounding_refs": {
          "type": "array",
          "items": {
            "$ref": "./grounding_ref.schema.json"
          }
        },
        "answer_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}