{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT V1 TOON Segment Registry",
  "type": "object",
  "required": [
    "registry_id",
    "schema_version",
    "row_definitions"
  ],
  "properties": {
    "registry_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "row_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "row_definition_id",
          "description",
          "allowed_packet_classes",
          "field_order"
        ],
        "properties": {
          "row_definition_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "allowed_packet_classes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "field_order": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$id": "https://bds.local/pact/v1/schemas/toon_segment_registry_v1.schema.json"
}
