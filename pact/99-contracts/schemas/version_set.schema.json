{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT V1 Version Set",
  "type": "object",
  "required": [
    "contract_version",
    "runtime_version",
    "corpus_version",
    "budget_version",
    "compatibility_posture"
  ],
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "runtime_version": {
      "type": "string"
    },
    "corpus_version": {
      "type": "string"
    },
    "budget_version": {
      "type": "string"
    },
    "compatibility_posture": {
      "type": "string",
      "enum": [
        "compatible",
        "migration_required",
        "incompatible"
      ]
    }
  },
  "additionalProperties": false,
  "$id": "https://bds.local/pact/v1/schemas/version_set.schema.json"
}