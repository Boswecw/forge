{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "eval_param_delta",
  "type": "object",
  "required": ["proposal_id", "node_revision", "deltas"],
  "additionalProperties": false,
  "properties": {
    "proposal_id": { "type": "string" },
    "node_revision": { "type": "string" },
    "deltas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "param_name", "current_value", "proposed_value", "bounded_delta",
          "raw_delta", "param_min", "param_max", "max_movement"
        ],
        "additionalProperties": false,
        "properties": {
          "param_name": { "type": "string" },
          "current_value": { "type": "number" },
          "proposed_value": { "type": "number" },
          "bounded_delta": { "type": "number" },
          "raw_delta": { "type": "number" },
          "param_min": { "type": "number" },
          "param_max": { "type": "number" },
          "max_movement": { "type": "number" }
        }
      }
    }
  }
}
