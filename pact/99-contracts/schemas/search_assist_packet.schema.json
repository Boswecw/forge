{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bds.local/pact/v1/schemas/search_assist_packet.schema.json",
  "title": "PACT V1 Search Assist Packet",
  "allOf": [
    {
      "$ref": "./packet_base.schema.json"
    },
    {
      "type": "object",
      "required": [
        "search_goal",
        "ranked_result_blocks",
        "selection_constraints",
        "grounding_refs",
        "result_count"
      ],
      "properties": {
        "packet_class": {
          "const": "search_assist_packet"
        },
        "search_goal": {
          "type": "string"
        },
        "ranked_result_blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "rank",
              "title",
              "source_ref",
              "summary"
            ],
            "properties": {
              "rank": {
                "type": "integer",
                "minimum": 1
              },
              "title": {
                "type": "string"
              },
              "source_ref": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "selection_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "grounding_refs": {
          "type": "array",
          "items": {
            "$ref": "./grounding_ref.schema.json"
          }
        },
        "result_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  ],
  "unevaluatedProperties": false
}