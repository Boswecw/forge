{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Forge Promotion Ledger Entry",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "promotion_id",
    "slice_name",
    "source_repo",
    "source_branch",
    "source_commit",
    "target_repo",
    "target_branch",
    "target_commit",
    "promoted_files",
    "excluded_files",
    "promotion_manifest",
    "proof_commands",
    "proof_results",
    "evidence_path",
    "runtime_status_proof",
    "authorforge_impact",
    "reviewer",
    "decision",
    "decision_reason",
    "created_at",
    "rollback_source_commit",
    "rollback_target_commit",
    "rollback_command",
    "rollback_evidence_path",
    "supersedes_promotion_id"
  ],
  "properties": {
    "promotion_id": { "type": "string", "minLength": 1 },
    "slice_name": { "type": "string", "minLength": 1 },
    "source_repo": { "type": "string", "minLength": 1 },
    "source_branch": { "type": "string" },
    "source_commit": { "type": "string" },
    "target_repo": { "type": "string" },
    "target_branch": { "type": "string" },
    "target_commit": { "type": "string" },
    "promoted_files": { "type": "array", "items": { "type": "string" } },
    "excluded_files": { "type": "array", "items": { "type": "string" } },
    "promotion_manifest": { "type": "array", "items": { "type": "string" } },
    "proof_commands": { "type": "array", "items": { "type": "string" } },
    "proof_results": { "type": ["object", "string", "null"] },
    "evidence_path": { "type": "string", "minLength": 1 },
    "runtime_status_proof": { "type": ["object", "string", "null"] },
    "authorforge_impact": { "type": ["object", "string", "null"] },
    "reviewer": { "type": "string" },
    "decision": {
      "type": "string",
      "enum": ["accepted", "rejected", "rollback", "needs-followup"]
    },
    "decision_reason": { "type": "string" },
    "created_at": { "type": "string" },
    "rollback_source_commit": { "type": "string" },
    "rollback_target_commit": { "type": "string" },
    "rollback_command": { "type": "string" },
    "rollback_evidence_path": { "type": "string" },
    "supersedes_promotion_id": { "type": ["string", "null"] }
  }
}
