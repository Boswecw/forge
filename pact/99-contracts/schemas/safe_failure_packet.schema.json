{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT V1 Safe Failure Packet",
  "type": "object",
  "required": [
    "schema_version",
    "failure_packet_id",
    "request_id",
    "trace_id",
    "packet_class",
    "failure_state",
    "retry_allowed",
    "operator_trace_ref",
    "public_reason_code"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "failure_packet_id": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "task_intent_id": {
      "type": "string"
    },
    "context_bundle_id": {
      "type": "string"
    },
    "context_bundle_hash": {
      "type": "string",
      "minLength": 8
    },
    "packet_class": {
      "type": "string",
      "enum": [
        "answer_packet",
        "policy_response_packet",
        "search_assist_packet"
      ]
    },
    "failure_state": {
      "type": "string",
      "enum": [
        "intake_rejection",
        "compiler_failure",
        "validation_failure",
        "grounding_failure",
        "budget_failure",
        "render_failure",
        "safe_failure"
      ]
    },
    "retry_allowed": {
      "type": "boolean"
    },
    "operator_trace_ref": {
      "type": "string"
    },
    "public_reason_code": {
      "type": "string",
      "enum": [
        "validation_failed",
        "grounding_unavailable",
        "over_budget",
        "permission_unresolved",
        "serialization_failed"
      ]
    }
  },
  "additionalProperties": false,
  "$id": "https://bds.local/pact/v1/schemas/safe_failure_packet.schema.json"
}
