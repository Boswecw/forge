{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "file:///mnt/data/pact_v1_artifact_pack/pact/99-contracts/schemas/search_assist_packet.schema.json",
  "title": "SearchAssistPacket",
  "allOf": [
    {
      "$ref": "file:///mnt/data/pact_v1_artifact_pack/pact/99-contracts/schemas/packet_base.schema.json"
    },
    {
      "type": "object",
      "required": [
        "search_goal",
        "ranked_result_blocks",
        "selection_constraints",
        "grounding_refs",
        "result_count"
      ],
      "properties": {
        "packet_class": {
          "const": "search_assist_packet"
        },
        "search_goal": {
          "type": "string",
          "minLength": 1
        },
        "ranked_result_blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "result_id",
              "title",
              "snippet",
              "score"
            ],
            "properties": {
              "result_id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "snippet": {
                "type": "string",
                "minLength": 1
              },
              "score": {
                "type": "number",
                "minimum": 0
              },
              "segment_ref": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
              }
            },
            "additionalProperties": false
          }
        },
        "selection_constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "grounding_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "file:///mnt/data/pact_v1_artifact_pack/pact/99-contracts/schemas/grounding_ref.schema.json"
          }
        },
        "result_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
