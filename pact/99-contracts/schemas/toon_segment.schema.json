{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT V1 TOON Segment",
  "type": "object",
  "required": [
    "segment_id",
    "segment_version",
    "row_definition_id",
    "row_count",
    "source_lineage_digest",
    "segment_hash",
    "toon_payload"
  ],
  "properties": {
    "segment_id": {
      "type": "string"
    },
    "segment_version": {
      "type": "string"
    },
    "row_definition_id": {
      "type": "string"
    },
    "row_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_lineage_digest": {
      "$ref": "./source_lineage_digest.schema.json"
    },
    "segment_hash": {
      "type": "string",
      "minLength": 16
    },
    "toon_payload": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false,
  "$id": "https://bds.local/pact/v1/schemas/toon_segment.schema.json"
}
