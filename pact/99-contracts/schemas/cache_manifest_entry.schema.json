{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT V1 Cache Manifest Entry",
  "type": "object",
  "required": [
    "cache_key",
    "packet_class",
    "permission_context_digest",
    "source_lineage_digest",
    "serialization_profile",
    "version_set",
    "created_at",
    "expires_at"
  ],
  "properties": {
    "cache_key": {
      "type": "string"
    },
    "packet_class": {
      "type": "string",
      "enum": [
        "answer_packet",
        "policy_response_packet",
        "search_assist_packet"
      ]
    },
    "permission_context_digest": {
      "type": "string",
      "minLength": 16
    },
    "source_lineage_digest": {
      "$ref": "./source_lineage_digest.schema.json"
    },
    "serialization_profile": {
      "$ref": "./serialization_profile_enum.schema.json"
    },
    "version_set": {
      "$ref": "./version_set.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$id": "https://bds.local/pact/v1/schemas/cache_manifest_entry.schema.json"
}
