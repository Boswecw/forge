{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT V1 Run Export Summary Package Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "export_package_id",
    "run_id",
    "transfer_id",
    "request_digest",
    "bundle_root",
    "source_run_index_path",
    "source_transfer_bundle_path",
    "source_transfer_manifest_path",
    "summary_path",
    "registry_record_path",
    "summary_manifest_path",
    "summary_package_path",
    "receipt_ids",
    "artifact_count",
    "included_artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "export_package_id": {
      "type": "string",
      "minLength": 8
    },
    "run_id": {
      "type": "string",
      "minLength": 8
    },
    "transfer_id": {
      "type": "string",
      "minLength": 8
    },
    "request_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "bundle_root": {
      "type": "string",
      "minLength": 1
    },
    "source_run_index_path": {
      "type": "string",
      "minLength": 1
    },
    "source_transfer_bundle_path": {
      "type": "string",
      "minLength": 1
    },
    "source_transfer_manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "summary_path": {
      "type": "string",
      "minLength": 1
    },
    "registry_record_path": {
      "type": "string",
      "minLength": 1
    },
    "summary_manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "summary_package_path": {
      "type": "string",
      "minLength": 1
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "artifact_count": {
      "type": "integer",
      "minimum": 1
    },
    "included_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_kind",
          "relative_path",
          "sha256"
        ],
        "properties": {
          "artifact_kind": {
            "type": "string",
            "enum": [
              "audit_transfer_bundle",
              "audit_transfer_manifest",
              "audit_summary",
              "registry_record"
            ]
          },
          "relative_path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$id": "https://bds.local/pact/v1/schemas/run_export_summary_package_manifest.schema.json"
}
