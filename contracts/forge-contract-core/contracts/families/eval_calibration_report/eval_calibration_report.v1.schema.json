{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "forge-contract-core/contracts/families/eval_calibration_report/v1",
  "title": "EvalCalibrationReportPayload",
  "description": "Payload for eval_calibration_report family v1. Normalizes forge-eval outputs and prepares bounded ForgeMath lane input.",
  "type": "object",
  "required": [
    "schema_version",
    "calibration_report_id",
    "source_forge_eval_evidence_bundle_ref",
    "source_artifact_hash",
    "repository_id",
    "score_normalization_version",
    "calibrated_scores",
    "confidence_band_candidate",
    "threshold_crossings",
    "validation_state"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "eval_cal_node.calibration_report.v1"
    },
    "calibration_report_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source_forge_eval_evidence_bundle_ref": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[0-9a-fA-F-]{36}:v[1-9][0-9]*$"
    },
    "source_artifact_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "repository_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "score_normalization_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "calibrated_scores": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": [
          "metric_name",
          "raw_score",
          "calibrated_score",
          "weight"
        ],
        "additionalProperties": false,
        "properties": {
          "metric_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "raw_score": {
            "type": "number"
          },
          "calibrated_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "confidence_band_candidate": {
      "type": "string",
      "enum": [
        "high_confidence",
        "medium_confidence",
        "low_confidence",
        "unknown"
      ]
    },
    "threshold_crossings": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": [
          "threshold_id",
          "crossed",
          "direction"
        ],
        "additionalProperties": false,
        "properties": {
          "threshold_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "crossed": {
            "type": "boolean"
          },
          "direction": {
            "type": "string",
            "enum": [
              "above",
              "below",
              "equal",
              "not_applicable"
            ]
          }
        }
      }
    },
    "validation_state": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "blocked"
      ]
    },
    "normalization_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 512
      },
      "maxItems": 20
    }
  }
}
