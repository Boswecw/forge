{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "eval_approval_request",
  "type": "object",
  "required": ["proposal_id", "node_revision", "requests"],
  "additionalProperties": false,
  "properties": {
    "proposal_id": { "type": "string" },
    "node_revision": { "type": "string" },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "param_name", "current_value", "proposed_value", "bounded_delta",
          "param_min", "param_max", "net_direction", "false_block_rate",
          "missed_block_rate", "n_total_implicated", "recurrence_count",
          "affected_surfaces", "recommendation"
        ],
        "additionalProperties": false,
        "properties": {
          "param_name": { "type": "string" },
          "current_value": { "type": "number" },
          "proposed_value": { "type": "number" },
          "bounded_delta": { "type": "number" },
          "param_min": { "type": "number" },
          "param_max": { "type": "number" },
          "net_direction": { "type": "number" },
          "false_block_rate": { "type": "number" },
          "missed_block_rate": { "type": "number" },
          "n_total_implicated": { "type": "integer", "minimum": 0 },
          "recurrence_count": { "type": "integer", "minimum": 0 },
          "affected_surfaces": {
            "type": "array",
            "items": { "type": "string" }
          },
          "recommendation": { "type": "string", "enum": ["accept", "decline"] }
        }
      }
    }
  }
}
