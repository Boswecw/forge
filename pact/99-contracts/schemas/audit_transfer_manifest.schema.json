{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT V1 Audit Transfer Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "transfer_id",
    "request_digest",
    "receipt_ids",
    "artifact_count",
    "transfer_bundle_filename",
    "transfer_catalog_filename",
    "included_artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "transfer_id": {
      "type": "string",
      "minLength": 8
    },
    "request_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "run_id": {
      "type": "string",
      "minLength": 8
    },
    "source_run_index_filename": {
      "type": "string",
      "minLength": 1
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "artifact_count": {
      "type": "integer",
      "minimum": 1
    },
    "transfer_bundle_filename": {
      "type": "string",
      "minLength": 1
    },
    "transfer_catalog_filename": {
      "type": "string",
      "minLength": 1
    },
    "included_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_kind",
          "relative_path",
          "sha256"
        ],
        "properties": {
          "artifact_kind": {
            "type": "string",
            "enum": [
              "catalog",
              "run_index",
              "export_manifest",
              "replay_package",
              "handoff_manifest"
            ]
          },
          "relative_path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$id": "https://bds.local/pact/v1/schemas/audit_transfer_manifest.schema.json"
}
