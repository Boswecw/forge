{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "forge-contract-core/contracts/families/forge_eval_evidence_bundle/v1",
  "title": "ForgeEvalEvidenceBundlePayload",
  "description": "Payload for forge_eval_evidence_bundle family v1. Deterministic forge-eval evidence bundle for Evaluation Spine handoff.",
  "type": "object",
  "required": [
    "schema_version",
    "forge_eval_run_id",
    "source_projection_id",
    "source_fused_bundle_id",
    "repository_id",
    "base_ref",
    "head_ref",
    "artifact_refs",
    "deterministic",
    "validation_state"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "forge_eval.evidence_bundle.v1"
    },
    "forge_eval_run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source_projection_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source_fused_bundle_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "repository_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "base_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "head_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": [
          "artifact_kind",
          "artifact_path",
          "artifact_hash"
        ],
        "additionalProperties": false,
        "properties": {
          "artifact_kind": {
            "type": "string",
            "enum": [
              "config_resolved",
              "risk_heatmap",
              "context_slices",
              "forge_eval_evidence_bundle",
              "other_governed"
            ]
          },
          "artifact_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "artifact_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "deterministic": {
      "type": "boolean",
      "const": true
    },
    "validation_state": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "blocked"
      ]
    },
    "validation_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "maxItems": 20
    }
  }
}
