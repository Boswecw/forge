{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "file:///mnt/data/pact_v1_artifact_pack/pact/99-contracts/schemas/answer_packet.schema.json",
  "title": "AnswerPacket",
  "allOf": [
    {
      "$ref": "file:///mnt/data/pact_v1_artifact_pack/pact/99-contracts/schemas/packet_base.schema.json"
    },
    {
      "type": "object",
      "required": [
        "task_goal",
        "instruction_block",
        "support_blocks",
        "grounding_refs",
        "answer_constraints"
      ],
      "properties": {
        "packet_class": {
          "const": "answer_packet"
        },
        "task_goal": {
          "type": "string",
          "minLength": 1
        },
        "instruction_block": {
          "type": "string",
          "minLength": 1
        },
        "support_blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "block_id",
              "kind",
              "content"
            ],
            "properties": {
              "block_id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "excerpt",
                  "summary",
                  "result_row",
                  "metadata_bundle"
                ]
              },
              "content": {
                "type": "string",
                "minLength": 1
              },
              "segment_ref": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
              }
            },
            "additionalProperties": false
          }
        },
        "grounding_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "file:///mnt/data/pact_v1_artifact_pack/pact/99-contracts/schemas/grounding_ref.schema.json"
          }
        },
        "answer_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
