{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "forge-contract-core/contracts/families/forgemath_lane_evaluation_ref/v1",
  "title": "ForgeMathLaneEvaluationRefPayload",
  "description": "Payload for forgemath_lane_evaluation_ref family v1. References ForgeMath canonical lane outputs without permitting downstream recalculation.",
  "type": "object",
  "required": [
    "schema_version",
    "lane_id",
    "lane_version",
    "source_eval_calibration_report_ref",
    "source_artifact_hash",
    "canonical_evaluation_ref",
    "canonical_score_ref",
    "threshold_decision_ref",
    "proposal_candidate_allowed",
    "rollback_required"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "forgemath.lane_evaluation_ref.v1"
    },
    "lane_id": {
      "type": "string",
      "const": "self_healing_candidate_confidence_v1"
    },
    "lane_version": {
      "type": "integer",
      "const": 1
    },
    "source_eval_calibration_report_ref": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[0-9a-fA-F-]{36}:v[1-9][0-9]*$"
    },
    "source_artifact_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "canonical_evaluation_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "canonical_score_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "threshold_decision_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "proposal_candidate_allowed": {
      "type": "boolean"
    },
    "rollback_required": {
      "type": "boolean"
    },
    "non_recalculation_notice": {
      "type": "string",
      "const": "Downstream systems must reference this ForgeMath result and must not recalculate canonical confidence, band, threshold, proposal allowance, or rollback decision."
    }
  }
}
