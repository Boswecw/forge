{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "file:///mnt/data/pact_v1_artifact_pack/pact/99-contracts/schemas/grounding_ref.schema.json",
  "title": "GroundingRef",
  "type": "object",
  "required": [
    "source_ref",
    "excerpt",
    "excerpt_hash",
    "authority_level"
  ],
  "properties": {
    "source_ref": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "excerpt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "excerpt_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "authority_level": {
      "type": "string",
      "enum": [
        "canonical",
        "strong_derived",
        "weak_derived",
        "provisional"
      ]
    }
  },
  "additionalProperties": false
}
