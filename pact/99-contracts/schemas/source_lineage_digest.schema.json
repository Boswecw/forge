{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PACT V1 Source Lineage Digest",
  "type": "object",
  "required": [
    "digest_algorithm",
    "digest",
    "source_scope"
  ],
  "properties": {
    "digest_algorithm": {
      "type": "string",
      "enum": [
        "sha256"
      ]
    },
    "digest": {
      "type": "string",
      "minLength": 16
    },
    "source_scope": {
      "type": "string",
      "enum": [
        "request",
        "packet",
        "segment",
        "cache_entry"
      ]
    }
  },
  "additionalProperties": false,
  "description": "Normalized source-lineage digest object.",
  "$id": "https://bds.local/pact/v1/schemas/source_lineage_digest.schema.json"
}