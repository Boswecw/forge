{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boswelldigital.com/forge/contracts/run_intent.v1.schema.json",
  "title": "RunIntent.v1",
  "description": "SMITH-signed wrapper around a GOVERNED PromptSpec (RTCFX Authority Layer) to initiate runs. Rev 2 includes intent_signature and hardened constraints.",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "version",
    "mode",
    "intent_id",
    "session_id",
    "issued_at",
    "nonce",
    "issuer_claims",
    "prompt_spec",
    "hashes",
    "pipeline_hooks",
    "smelter_hooks",
    "evidence_requirements"
  ],

  "properties": {
    "version": {
      "type": "string",
      "const": "run_intent.v1"
    },

    "mode": {
      "type": "string",
      "enum": ["governed", "peek"],
      "description": "governed = may create work/mutate repos; peek = read-only analysis only"
    },

    "intent_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique intent identifier; used in replay prevention and evidence indexing"
    },

    "session_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9._:-]+$",
      "description": "Pipeline/ledger session id (ties to pipeline state machine)"
    },

    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "When SMITH issued the intent"
    },

    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "Expiry for intent acceptance (REQUIRED for governed runs)"
    },

    "nonce": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9+/=_-]+$",
      "description": "Replay protection nonce (must be unique per issuer_id + intent_id)"
    },

    "issuer_claims": {
      "$ref": "#/$defs/IssuerClaims"
    },

    "prompt_spec": {
      "$ref": "#/$defs/PromptSpecGoverned"
    },

    "hashes": {
      "$ref": "#/$defs/Hashes"
    },

    "pipeline_hooks": {
      "$ref": "#/$defs/PipelineHooks"
    },

    "smelter_hooks": {
      "$ref": "#/$defs/SmelterHooks"
    },

    "evidence_requirements": {
      "$ref": "#/$defs/EvidenceRequirements"
    },

    "intent_signature": {
      "type": "string",
      "minLength": 16,
      "maxLength": 4096,
      "description": "Signature over canonical RunIntent bytes (binds hooks + evidence requirements). REQUIRED for governed mode."
    },

    "notes": {
      "type": "string",
      "maxLength": 4000,
      "description": "Optional operator notes (non-authoritative)"
    }
  },

  "allOf": [
    {
      "if": {
        "properties": { "mode": { "const": "governed" } },
        "required": ["mode"]
      },
      "then": {
        "required": ["expires_at", "intent_signature"],
        "properties": {
          "prompt_spec": {
            "properties": {
              "context_class": { "const": "GOVERNED" },
              "issuer_id": { "const": "forge:smith" }
            },
            "required": ["context_class", "issuer_id", "issuer_signature"]
          },
          "issuer_claims": {
            "properties": {
              "issuer_id": { "const": "forge:smith" },
              "authority_ring": { "const": 0 }
            },
            "required": ["issuer_id", "authority_ring"]
          },
          "evidence_requirements": {
            "properties": {
              "bundle_required": { "const": true },
              "release_affidavit_allowed": { "const": true }
            },
            "required": ["bundle_required", "release_affidavit_allowed"]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "mode": { "const": "peek" } },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "evidence_requirements": {
            "properties": {
              "bundle_required": { "const": false },
              "release_affidavit_allowed": { "const": false }
            },
            "required": ["bundle_required", "release_affidavit_allowed"]
          },
          "pipeline_hooks": {
            "properties": {
              "allows_repo_mutation": { "const": false }
            },
            "required": ["allows_repo_mutation"]
          },
          "prompt_spec": {
            "properties": {
              "constraints": {
                "properties": {
                  "scope": {
                    "properties": {
                      "allows_repo_mutation": { "const": false },
                      "allows_deploy": { "const": false }
                    },
                    "required": ["allows_repo_mutation", "allows_deploy"]
                  }
                },
                "required": ["scope"]
              }
            },
            "required": ["constraints"]
          }
        }
      }
    }
  ],

  "$defs": {
    "IssuerClaims": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issuer_id", "authority_ring", "issuer_instance", "alg"],
      "properties": {
        "issuer_id": {
          "type": "string",
          "const": "forge:smith",
          "description": "Issuer identity (SMITH)"
        },
        "authority_ring": {
          "type": "integer",
          "enum": [0],
          "description": "Ring 0 only for governed intent issuance"
        },
        "issuer_instance": {
          "type": "string",
          "minLength": 6,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9._:-]+$",
          "description": "Specific SMITH instance identity (from get_smith_identity)"
        },
        "alg": {
          "type": "string",
          "enum": ["ed25519", "secp256k1", "p256"],
          "description": "Signature algorithm used for issuer_signature"
        },
        "kid": {
          "type": "string",
          "minLength": 4,
          "maxLength": 128,
          "description": "Key id (optional but recommended)"
        }
      }
    },

    "PromptSpecGoverned": {
      "type": "object",
      "additionalProperties": false,
      "description": "GOVERNED-only PromptSpec wrapper for RunIntent (PUBLIC specs use separate schema)",
      "required": [
        "spec_version",
        "context_class",
        "issuer_id",
        "issuer_signature",
        "operation",
        "inputs",
        "constraints"
      ],
      "properties": {
        "spec_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "PromptSpec version (e.g., prompt_spec.v1)"
        },
        "context_class": {
          "type": "string",
          "const": "GOVERNED",
          "description": "Must be GOVERNED for RunIntent"
        },
        "issuer_id": {
          "type": "string",
          "const": "forge:smith",
          "description": "Must be forge:smith for governed runs"
        },
        "issuer_signature": {
          "type": "string",
          "minLength": 16,
          "maxLength": 4096,
          "description": "Signature over canonical PromptSpec bytes (JCS/RFC8785)"
        },
        "operation": {
          "$ref": "#/$defs/Operation"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": true,
          "description": "Operation inputs (must be hashed via canonicalization)"
        },
        "constraints": {
          "$ref": "#/$defs/Constraints"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "description": "Non-authoritative metadata; do not include secrets"
        }
      }
    },

    "Operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9_.:-]+$",
          "description": "Operation name (maps to ForgeAgents skill/capability or SMITH workflow)"
        },
        "capability_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Z]{1,2}-\\d{3}$",
          "description": "Optional: ForgeAgents capability id (e.g., E-081)"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 3600000
        }
      }
    },

    "Constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_allowlist", "scope"],
      "properties": {
        "repo_allowlist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allows_repo_mutation", "allows_deploy"],
          "properties": {
            "allows_repo_mutation": { "type": "boolean" },
            "allows_deploy": { "type": "boolean" }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": true,
          "description": "Policy constraints (SAS/mandates/doctrine flags)"
        }
      }
    },

    "Hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_sha256", "promptspec_canonical_sha256"],
      "properties": {
        "canonical_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 of canonical RunIntent bytes (lowercase hex)"
        },
        "promptspec_canonical_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 of canonical PromptSpec bytes (lowercase hex)"
        },
        "input_canonical_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Optional: hash of canonicalized inputs block (lowercase hex)"
        }
      }
    },

    "PipelineHooks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason_code", "target_state", "hardening_required", "allows_repo_mutation"],
      "properties": {
        "reason_code": {
          "type": "string",
          "minLength": 2,
          "maxLength": 64,
          "pattern": "^[A-Z0-9_]+$",
          "description": "Reason code mapped to pipeline transitions (e.g., BLOCKED_AUTH, BLOCKED_DRIFT)"
        },
        "target_state": {
          "type": "string",
          "enum": [
            "IDLE",
            "WELCOME_FIRST_RUN",
            "SELECTED",
            "EVALUATING",
            "AWAITING_AUTH",
            "EXECUTING",
            "VERIFYING_EVIDENCE",
            "REVIEWING",
            "DONE",
            "ERROR"
          ],
          "description": "Expected pipeline state when this intent is accepted"
        },
        "hardening_required": {
          "type": "boolean",
          "description": "If true, requires guard_hardening_read/guard_run pass before execution"
        },
        "allows_repo_mutation": {
          "type": "boolean",
          "description": "Must be false in peek mode"
        },
        "governance_proposal_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Optional: link to /governance/proposals/[gap_id] when in AWAITING_AUTH"
        }
      }
    },

    "SmelterHooks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drift_state", "trust_tier", "trust_debt_delta"],
      "properties": {
        "drift_state": {
          "type": "string",
          "enum": ["Live", "Stale", "Rewritten", "DirtyDrift", "Detached", "Unknown"],
          "description": "SMELTER drift state at issuance"
        },
        "trust_tier": {
          "type": "string",
          "enum": ["T0", "T1", "T2", "T3", "T4"],
          "description": "Trust tier at issuance"
        },
        "trust_debt_delta": {
          "type": "integer",
          "minimum": -1000,
          "maximum": 1000,
          "default": 0,
          "description": "Expected delta (e.g., emergency brake increases trust debt). Default 0."
        },
        "smelter_pack_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "description": "Reference to SMELTER pack (hash/id) used for context binding"
        }
      }
    },

    "EvidenceRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundle_required", "release_affidavit_allowed"],
      "properties": {
        "bundle_required": {
          "type": "boolean",
          "description": "true for governed runs, false for peek"
        },
        "release_affidavit_allowed": {
          "type": "boolean",
          "description": "Must be false for peek runs"
        },
        "bundle_profile": {
          "type": "string",
          "enum": ["standard", "deep", "forensic"],
          "default": "standard"
        },
        "required_artifacts": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["manifest.json", "hashes.json", "artifacts/input.json", "artifacts/output.json"]
        }
      }
    }
  }
}
